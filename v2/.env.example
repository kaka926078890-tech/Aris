# DeepSeek API (required for dialogue，与 v1 一致)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_API_URL=https://api.deepseek.com
# 对 ECONNRESET / terminated 等瞬时网络错误重试次数（默认 5 次请求）；可略增以缓解不稳定网络
# ARIS_LLM_MAX_RETRIES=5
# 单次重试前等待基数（ms），实际为 base * 2^attempt（默认 400）
# ARIS_LLM_RETRY_BASE_MS=400
# 设为 false 时不再为 LLM 请求加 Connection:close（默认开启，减轻「Planner 成功、chatWithTools 失败」类断连）
# ARIS_LLM_HTTP_CLOSE=true

# 本机调试：为 true 或 1 时，在运行后端的终端打印发往 DeepSeek 的 JSON 请求体（chat、chatWithTools、chatStream；含 messages、stream 等；体积大且含隐私）
# chatWithTools 默认不打印 tools 数组（过长）；需要连 tools 一并打印时再设下方变量
# ARIS_DEBUG_DEEPSEEK_REQUEST_BODY=true
# ARIS_DEBUG_DEEPSEEK_TOOLS=true

# Optional: Ollama for local embeddings (LanceDB memory，与 v1 一致)
OLLAMA_HOST=http://localhost:11434
ARIS_EMBED_MODEL=nomic-embed-text

# Optional: LLM max tokens（与 v1 一致，默认 8192）
# ARIS_STREAM_MAX_TOKENS=8192
# ARIS_TOOL_MAX_TOKENS=8192

# Prompt Planner：主对话前多一次 LLM 编排（默认关闭；需改为 true 才启用）
# ARIS_PROMPT_PLANNER_ENABLED=true
# 不设或 false 时与关闭 Planner 相同：全文用户约束 + 全场景规则（LEGACY）
# ARIS_PROMPT_PLANNER_MAX_TOKENS=400
# 为 true 时在数据目录写入 prompt_planner_metrics.jsonl
# ARIS_PROMPT_PLANNER_LOG=false

# 单轮对话观测：默认写入数据目录 dialogue_turn_metrics.jsonl（planner 耗时、工具轮次、文件类工具次数、embed 耗时等）；设为 false 可关闭
# ARIS_DIALOGUE_METRICS_LOG=true

# 主对话采样温度（0～2），默认 0.62，略利于风格稳定；需要更活泼可调高
# ARIS_CHAT_TEMPERATURE=0.62

# 单条用户消息内工具调用最大轮数（含多轮工具），默认 25；需要长链路工具时可调高
# ARIS_MAX_TOOL_ROUNDS=25

# emotion / expression_desire / self_note 是否后台异步写入（默认异步）；设为 false 则全部同步落盘后再返回
# ARIS_RECORD_ASYNC=true

# 对话后轮次：向量写入、token 监控、dialogue_turn_metrics 是否走持久化异步队列（默认开启，含重试/死信/启动补录）
# 设为 false 则与旧版一致：同步 embed + 同步写监控与指标
# ARIS_ASYNC_OUTBOX=true
# ARIS_ASYNC_OUTBOX_MAX_RETRIES=5
# ARIS_ASYNC_OUTBOX_INTERVAL_MS=2000
# ARIS_ASYNC_OUTBOX_STARTUP_BURST=80

# Optional: v2 data directory (default: Electron userData/aris-v2 or v2/data)
# 本机开发：设为 ./data 时数据在 v2/data，便于直接查看/编辑 memory（在 v2 目录下启动时）
ARIS_V2_DATA_DIR=./data

# 无 Electron 时用浏览器（完整 UI 与 apps/renderer/index.html 一致）：v2 目录 npm run web-chat → http://127.0.0.1:8780
# ARIS_WEB_CHAT_PORT=8780
# 可选；设置后需在浏览器控制台：localStorage.setItem('aris_web_chat_bearer','与下方相同的 token') 后刷新，所有 API 会带 Bearer
# ARIS_WEB_CHAT_TOKEN=

# 官方 QQ 机器人桥接：v2 目录下 npm run qq-bridge（见 docs/qq_bot_official_integration.md 方案二）
# 监听 127.0.0.1，POST /chat JSON { "text", "sessionId" }，需与 DeepSeek 等同机配置
# ARIS_QQ_BRIDGE_PORT=8765
# 本机示例：随机一串即可；请求头 Authorization: Bearer <token>。不设则任意进程可调用（仅调试）
# ARIS_QQ_BRIDGE_TOKEN=
# 腾讯 QQ 开放平台（控制台「机器人」页：AppID、Token、秘钥 ClientSecret、机器人 QQ 号）
# 仅用于网关/桥接读取环境变量，勿提交到 Git
# QQ_BOT_APP_ID=
# QQ_BOT_APP_SECRET=
# QQ_BOT_TOKEN=
# QQ_BOT_UIN=
# 官方 OpenAPI 域名（默认 https://api.sgroup.qq.com，按官方文档调整）
# QQ_BOT_OPENAPI_BASE=https://api.sgroup.qq.com
# QQ 回调会话映射策略：group_member（群内按人隔离，默认）| group_shared（整群共享）
# ARIS_QQ_SESSION_MODE=group_member

# Puppeteer（fetch_url 且 use_js: true 时）：package.json 已 skipDownload，安装阶段不再拉取 Chrome 压缩包（避免网络/镜像导致 ZIP 损坏）。
# 运行时使用本机已安装的 Chrome；无 Chrome 时可设 Edge：PUPPETEER_BROWSER_CHANNEL=msedge，或指定可执行文件：
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# 若坚持 install 时下载内置浏览器，可暂时从 package.json 删除 "puppeteer".skipDownload 后重跑 npm install（需稳定访问 Google 或正确镜像）
# PUPPETEER_BROWSER_CHANNEL=chrome

# Optional: 网络访问工具 fetch_url（配置见 README 可配置项 network_config.json）
# 本机测试：开启后可在对话中让 Aris 抓取网页；关闭则隐藏该工具
ENABLE_WEB_FETCH=true
# 本机一般可不设；若只允许访问部分域名可设白名单，逗号分隔，如：WEB_FETCH_ALLOWED_HOSTS=example.com,api.example.com
# WEB_FETCH_ALLOWED_HOSTS=
# 黑名单，默认已含 localhost,127.0.0.1；本机可省略
# WEB_FETCH_BLOCKED_HOSTS=localhost,127.0.0.1
# 超时(ms)、每分钟最多调用次数、返回正文最大字符数；本机可省略
# WEB_FETCH_TIMEOUT_MS=15000
# WEB_FETCH_MAX_CALLS_PER_MINUTE=10
# WEB_FETCH_MAX_LENGTH=8000
