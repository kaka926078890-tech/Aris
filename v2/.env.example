# DeepSeek API (required for dialogue，与 v1 一致)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_API_URL=https://api.deepseek.com
# 对 ECONNRESET / terminated 等瞬时网络错误重试次数（默认 5 次请求）；可略增以缓解不稳定网络
# ARIS_LLM_MAX_RETRIES=5
# 单次重试前等待基数（ms），实际为 base * 2^attempt（默认 400）
# ARIS_LLM_RETRY_BASE_MS=400
# 设为 false 时不再为 LLM 请求加 Connection:close（默认开启，减轻对端/代理对同一 keep-alive 上第二次大包断连）
# ARIS_LLM_HTTP_CLOSE=true

# DeepSeek 请求体调试：默认关闭（不设、留空、false 均不打印）。仅本机排查时再设为 true 或 1
# ARIS_DEBUG_DEEPSEEK_REQUEST_BODY=false
# chatWithTools 默认不打印 tools 数组（过长）；需要连 tools 一并打印时再设下方为 true
# ARIS_DEBUG_DEEPSEEK_TOOLS=false

# Optional: Ollama for local embeddings (LanceDB memory，与 v1 一致)
OLLAMA_HOST=http://localhost:11434
ARIS_EMBED_MODEL=nomic-embed-text

# 向量记忆检索（最终方案，默认开启）：混合召回 → 池内余弦融合 → RRF+字面覆盖 第二阶段 → 再乘 sim/time（默认时间权重 0）
# 设为 false 或 0 时回退为「纯向量 + 可选时间项」（旧混合关闭行为）
# ARIS_MEMORY_HYBRID=true
# 设为 false 时回退旧「仅混合余弦 + 时间」排序，不使用 RRF/字面第二阶段
# ARIS_MEMORY_FINAL_STAGE2=true
# 混合阶段：向量候选条数、全文候选条数（约越大召回越全、略慢）
# ARIS_HYBRID_VECTOR_FETCH=120
# ARIS_HYBRID_BM25_FETCH=120
# 进入余弦重排的候选池大小（混合分排序后取前 N 条再与向量余弦融合）
# ARIS_RERANK_POOL_SIZE=40
# 混合融合权重（内部会按和归一化）：向量相似度 / BM25 分数
# ARIS_HYBRID_VECTOR_WEIGHT=0.4
# ARIS_HYBRID_BM25_WEIGHT=0.4
# 重排阶段：混合分与余弦相似度的权重（内部会按和归一化）
# ARIS_RERANK_HYBRID_WEIGHT=0.45
# ARIS_RERANK_COSINE_WEIGHT=0.55
# 第二阶段：RRF 倒数排名融合 / 混合余弦残差 / 字面覆盖 的相对权重（内部会按和归一化）
# ARIS_RRF_FUSION_WEIGHT=0.45
# ARIS_HYBRID_COS_RESIDUAL_WEIGHT=0.35
# ARIS_LEXICAL_FUSION_WEIGHT=0.2
# RRF 公式中的 k（默认 60）
# ARIS_RRF_K=60
# 向量层最终得分：相关性 × sim 权重 + 时间 × time 权重（默认 1 与 0，即不随时间压旧记忆）
# ARIS_VECTOR_SIMILARITY_WEIGHT=1
# ARIS_VECTOR_TIME_WEIGHT=0
# Optional: LLM max tokens（与 v1 一致，默认 8192）
# ARIS_STREAM_MAX_TOKENS=8192
# ARIS_TOOL_MAX_TOKENS=8192

# 单轮对话观测：默认写入数据目录 dialogue_turn_metrics.jsonl（工具轮次、文件类工具次数、embed 耗时等）；设为 false 可关闭
# ARIS_DIALOGUE_METRICS_LOG=true

# 主对话采样温度（0～2），默认 0.62，略利于风格稳定；需要更活泼可调高
# ARIS_CHAT_TEMPERATURE=0.62

# 单条用户消息内工具调用最大轮数（含多轮工具），默认 25；需要长链路工具时可调高
# ARIS_MAX_TOOL_ROUNDS=25

# 单条用户消息内「文件类」工具（list/read/cache/write/delete/get_my_context 等）最大调用次数；默认 1000，硬顶 100000
# ARIS_FILE_TOOL_MAX_PER_USER_TURN=1000
# read_file 返回正文截断长度（字符）；默认约 200 万，硬顶 2000 万；过大易撑爆上下文与内存
# ARIS_READ_FILE_MAX_CHARS=2000000

# emotion / expression_desire / self_note 是否后台异步写入（默认异步）；设为 false 则全部同步落盘后再返回
# ARIS_RECORD_ASYNC=true

# 对话后轮次：向量写入、token 监控、dialogue_turn_metrics 是否走持久化异步队列（默认开启，含重试/死信/启动补录）
# 设为 false 则与旧版一致：同步 embed + 同步写监控与指标
# ARIS_ASYNC_OUTBOX=true
# ARIS_ASYNC_OUTBOX_MAX_RETRIES=5
# ARIS_ASYNC_OUTBOX_INTERVAL_MS=2000
# ARIS_ASYNC_OUTBOX_STARTUP_BURST=80

# Optional: v2 data directory (default: Electron userData/aris-v2 or v2/data)
# 本机开发：设为 ./data 时数据在 v2/data，便于直接查看/编辑 memory（在 v2 目录下启动时）
ARIS_V2_DATA_DIR=./data

# 无 Electron 时用浏览器（完整 UI 与 apps/renderer/index.html 一致）：v2 目录 npm run web-chat → http://127.0.0.1:8780
# ARIS_WEB_CHAT_PORT=8780
# 可选；设置后需在浏览器控制台：localStorage.setItem('aris_web_chat_bearer','与下方相同的 token') 后刷新，所有 API 会带 Bearer
# ARIS_WEB_CHAT_TOKEN=

