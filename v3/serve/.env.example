# === 服务监听 ===
PORT=7899
HOST=0.0.0.0

# === 本地数据目录（sqlite + 向量） ===
ARIS_V2_DATA_DIR=./data
# 兼容旧变量名（可不填）
# ARIS_DATA_DIR=./data

# === 对话模型（直接复用 v2 变量） ===
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_API_URL=https://api.deepseek.com
LLM_DEFAULT_MODEL=deepseek-chat
LLM_TIMEOUT_MS=60000
# 流式最后一包是否请求 usage（与 v2 控制台 token 统计对齐）；若对端报错可设 false
ARIS_LLM_STREAM_INCLUDE_USAGE=true

# === 向量模型（直接复用 v2 变量） ===
OLLAMA_HOST=http://127.0.0.1:11434
ARIS_EMBED_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# === 网络工具（web_search / web_fetch） ===
# true: 允许模型调用联网工具；false: 完全禁用 web_search/web_fetch
ARIS_WEB_TOOLS_ENABLED=true
# web_search 提供商（默认 Tavily）
ARIS_WEB_SEARCH_API_URL=https://api.tavily.com/search
# 申请地址：https://tavily.com/
ARIS_WEB_SEARCH_API_KEY=
# 每次 web_search 默认返回条数（可在工具参数覆盖）
ARIS_WEB_SEARCH_MAX_RESULTS=5
# web_fetch 抓取超时（毫秒）
ARIS_WEB_FETCH_TIMEOUT_MS=12000
# web_fetch 默认正文截断长度（字符）
ARIS_WEB_FETCH_MAX_CHARS=12000

# === 提示词预算（token） ===
PROMPT_TOKEN_BUDGET=8000
PROMPT_SYSTEM_BUDGET=1500
PROMPT_MEMORY_BUDGET=3000
PROMPT_USER_BUDGET=3500
PROMPT_RECENT_TURNS=10
PROMPT_RETRIEVAL_ENABLED=true
PROMPT_RETRIEVAL_TOP_K_TURN=4
PROMPT_RETRIEVAL_TOP_K_MESSAGE=4
PROMPT_RETRIEVAL_SCORE_THRESHOLD=0.45
# true: 不从当前会话检索，避免与 recent history 重复注入
PROMPT_RETRIEVAL_EXCLUDE_CURRENT_CONVERSATION=true
# 检索排序时间衰减：adjusted = score * exp(-天数 * λ)；0 表示关闭（默认）
PROMPT_RETRIEVAL_TIME_DECAY_PER_DAY=0

# === 会话引擎：compaction（OpenClaw 式：摘要 + 尾部原文）===
# false 时关闭自动压缩（仍保留 DB 中已有摘要行，可按需清空表）
PROMPT_COMPACTION_ENABLED=true
# 0 表示使用 PROMPT_RECENT_TURNS*2 作为「尾部保留」消息条数
PROMPT_COMPACTION_TAIL_MESSAGES=0
# 估算 token 超过 PROMPT_MEMORY_BUDGET * 该比例时可能触发压缩（与长度启发并用）
PROMPT_COMPACTION_TOKEN_TRIGGER_RATIO=0.85
# 最近 N 条 assistant 消息保留 metadata.tool_trace，更早轮剔除以省 token
PROMPT_COMPACTION_PRUNE_METADATA_KEEP_LAST=8

# === 日志 ===
# info：仅 token 用量 + 每轮结束摘要；debug：HTTP/工具/提示词组装等
LOG_LEVEL=info
# true 时终端打印完整 LLM messages（调试）；默认只打条数与估算输入 token
ARIS_DEBUG_LLM_REQUEST_BODY=false
# true 时输出更易读的本地日志
LOG_PRETTY=true
