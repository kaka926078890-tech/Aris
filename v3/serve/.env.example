# === Server ===
PORT=3000
HOST=0.0.0.0

# === Data directory (SQLite + vectors) ===
ARIS_DATA_DIR=./data

# === LLM (OpenAI-compatible) ===
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_DEFAULT_MODEL=gpt-4o-mini
# Optional: separate reasoning model for complex queries (unused in MVP)
LLM_REASONING_MODEL=
LLM_TIMEOUT_MS=60000

# === Embedding ===
# Falls back to LLM_API_KEY / LLM_BASE_URL if not set
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=20

# === Prompt budget (tokens) ===
PROMPT_TOKEN_BUDGET=8000
PROMPT_SYSTEM_BUDGET=1500
PROMPT_MEMORY_BUDGET=3000
PROMPT_USER_BUDGET=3500
PROMPT_RECENT_TURNS=10

# === Retrieval ===
RETRIEVAL_ENABLED=true
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.7

# === Embedding queue ===
EMBEDDING_QUEUE_CONCURRENCY=2
EMBEDDING_QUEUE_RETRIES=3
EMBEDDING_QUEUE_RETRY_DELAY_MS=1000

# === Logging ===
LOG_LEVEL=info
# Set to true for human-readable dev logs
LOG_PRETTY=true
